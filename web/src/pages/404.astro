---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Not found | Cyberd" description="The requested page was not found.">
  <section class="container py-20">
    <div class="surface p-8">
      <p class="eyebrow accent-crimson">404</p>
      <h1 class="mt-3 text-7xl font-black tracking-[-0.09em]">Wrong alley.</h1>
      <p class="mt-4 max-w-xl text-xl leading-8 text-muted">
        This page does not exist, or it moved during a rebuild.
      </p>
      <a class="button mt-8" href="/">Return home</a>
    </div>
  </section>
</BaseLayout>
