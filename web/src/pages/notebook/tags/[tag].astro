---
import Card from "@components/Card.astro";
import NotebookControls from "@components/NotebookControls.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { normalizeSlug, slugLabel, sortByDateDesc } from "@lib/content";

export async function getStaticPaths() {
  const notebook = await getCollection("notebook", ({ data }) => !data.draft);
  const tags = Array.from(new Set(notebook.flatMap((entry) => entry.data.tags.map(normalizeSlug))));

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      entries: sortByDateDesc(notebook.filter((entry) => entry.data.tags.map(normalizeSlug).includes(tag))),
    },
  }));
}

const { tag, entries } = Astro.props;
---

<BaseLayout title={`#${slugLabel(tag)} | Notebook Tags | Cyberd`} description={`Notebook entries tagged ${slugLabel(tag)}.`} agentHref="/notebook.md">
  <section class="container py-14" data-notebook-filter>
    <a class="font-mono text-sm font-bold" href="/notebook">&lt;- Notebook</a>
    <p class="eyebrow accent-sky mt-6">Tag</p>
    <h1 class="mt-3 text-6xl font-black tracking-[-0.09em]">#{slugLabel(tag)}</h1>
    <div class="mt-8 min-w-0">
      <NotebookControls sortMenuId="notebook-sort-tag" />
      <div class="grid-auto" data-notebook-list>
        {
          entries.map((entry) => (
            <Card
              href={`/notebook/${entry.id}`}
              eyebrow={entry.data.category}
              title={entry.data.title}
              summary={entry.data.excerpt}
              complexity={entry.data.complexity}
              date={entry.data.date.valueOf()}
            />
          ))
        }
      </div>
      <p class="text-muted mt-6 is-hidden" data-notebook-empty>No articles match this technical depth yet.</p>
    </div>
  </section>
  <script>
    import { initNotebookFilters } from "../../../lib/notebook-filter";
    initNotebookFilters();
  </script>
</BaseLayout>
