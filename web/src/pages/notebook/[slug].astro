---
import { getCollection, render } from "astro:content";
import ComplexityBadge from "@components/ComplexityBadge.astro";
import TagList from "@components/TagList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { articleJsonLd } from "@lib/jsonld";
import { formatLabel } from "@lib/content";

export async function getStaticPaths() {
  const notebook = await getCollection("notebook", ({ data }) => !data.draft);
  return notebook.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} | Notebook | Cyberd`}
  description={entry.data.excerpt}
  jsonLd={articleJsonLd(entry)}
  agentHref={`/notebook/${entry.id}.md`}
>
  <article class="container py-14">
    <a class="font-mono text-sm font-bold" href="/notebook">&lt;- Notebook</a>
    <header class="notebook-article-header surface mt-5 p-6 md:p-8">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <p class="eyebrow accent-sky">{formatLabel(entry.data.category)}</p>
        <ComplexityBadge level={entry.data.complexity} />
      </div>
      <h1 class="notebook-article-title mt-3 text-5xl md:text-7xl">{entry.data.title}</h1>
      <p class="mt-5 max-w-3xl text-xl leading-8 text-muted">{entry.data.excerpt}</p>
      <div class="mt-6 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <TagList tags={entry.data.tags} />
        <time class="font-mono text-sm font-bold" datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
        </time>
      </div>
    </header>
    <div class="prose article-prose mt-8 p-6 md:p-8" data-pagefind-body>
      <span data-pagefind-meta={`title:${entry.data.title}`} hidden></span>
      <span data-pagefind-meta="type:Notebook" hidden></span>
      <span data-pagefind-meta={`complexity:${entry.data.complexity}`} hidden></span>
      <Content />
    </div>
  </article>
</BaseLayout>
