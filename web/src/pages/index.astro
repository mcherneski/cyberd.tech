---
import Card from "@components/Card.astro";
import ContactForm from "@components/ContactForm.astro";
import ContentCarousel from "@components/ContentCarousel.astro";
import ExperienceTimeline from "@components/ExperienceTimeline.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSiteContent } from "@lib/content";
import { personJsonLd } from "@lib/jsonld";
import { siteConfig } from "@lib/site";

const { projects, notebook, papers, testimonials, credentials } = await getSiteContent();
---

<BaseLayout jsonLd={personJsonLd()} agentHref="/index.md">
  <section class="container py-14 md:py-20">
    <div class="grid gap-8 md:grid-cols-[1.1fr_0.9fr] md:items-stretch">
      <div class="reveal md:flex md:flex-col md:justify-center">
        <p class="eyebrow accent-sky">Mike Cherneski · Enterprise Architect &amp; builder · Asheville, NC</p>
        <h1 class="mt-4 text-6xl font-black leading-[0.92] tracking-[-0.09em] md:text-7xl">
          Enterprise Architect by trade. Builder by nature.
        </h1>
        <p class="text-muted mt-6 max-w-2xl text-xl leading-8">
         Helping forward-looking teams adopt AI and modernize the enterprise stack. Technology holds immense promise. Capturing it takes a strict foundation. I work on both.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button" href="#contact">Work with me</a>
          <a class="button button-secondary" href="#projects">See projects</a>
        </div>
      </div>
      <aside class="surface p-5 md:flex md:min-h-[36rem] md:flex-col">
        <div class="flex flex-row items-center gap-4 md:flex-1 md:flex-col md:items-stretch">
          <img
            class="portrait w-24 shrink-0 sm:w-28 md:mb-4 md:aspect-auto md:min-h-0 md:w-full md:flex-1 md:object-cover"
            src={siteConfig.photo}
            alt="Mike Cherneski"
            width="720"
            height="900"
            decoding="async"
          />
          <div class="min-w-0">
            <p class="eyebrow accent-green">Mike Cherneski</p>
            <p class="mt-1 font-bold leading-6">
              Founder &amp; Principal Architect, Cyberd
            </p>
            <p class="text-muted mt-2 text-sm">Building across AI, cloud, blockchain, and hardware.</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section id="projects" class="container py-12" data-project-filter>
    <div class="mb-6 flex flex-col gap-4">
      <div>
        <p class="eyebrow accent-yellow">Selected work</p>
        <h2 class="text-4xl font-black tracking-[-0.07em]" data-project-filter-heading aria-live="polite">
          The work comes first.
        </h2>
      </div>
      <div class="seg w-full" role="group" aria-label="Filter projects by type">
        <button type="button" class="seg-btn is-active" data-filter="all" aria-pressed="true">All</button>
        <button type="button" class="seg-btn" data-filter="professional" aria-pressed="false">Professional</button>
        <button type="button" class="seg-btn" data-filter="hobby" aria-pressed="false">Hobby</button>
      </div>
    </div>
    <div class="grid-auto">
      {
        projects.slice(0, 6).map((project, index) => (
          <Card
            href={`/projects/${project.id}`}
            eyebrow={project.data.category}
            title={project.data.title}
            summary={project.data.summary}
            accent={index % 3 === 0 ? "sky" : index % 3 === 1 ? "yellow" : "crimson"}
            context={project.data.context}
          />
        ))
      }
    </div>
    <p class="text-muted mt-6 is-hidden" data-empty-state>Nothing here yet. New projects in this category are on the way.</p>
    <div class="mt-8">
      <a class="button button-secondary" href="/projects">Full project archive -></a>
    </div>
  </section>
  <script>
    import { initProjectFilters } from "../lib/project-filter";
    initProjectFilters();
  </script>

  <ExperienceTimeline credentials={credentials} linkHref="/about" />

  {
    testimonials.length > 0 && (
      <section class="container pb-12">
        <div class="surface p-6">
          <p class="eyebrow accent-crimson">Testimonials</p>
          <h2 class="mt-3 text-4xl font-black tracking-[-0.07em]">Outside signal.</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {testimonials.slice(0, 2).map((item) => (
              <blockquote class="surface-muted p-4">
                <p class="text-lg font-bold leading-7">"{item.data.quote}"</p>
                <footer class="mt-3 font-mono text-xs font-bold uppercase tracking-widest">
                  {item.data.name}, {item.data.role}
                </footer>
              </blockquote>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <ContentCarousel notebook={notebook} papers={papers} />
  <ContactForm />
</BaseLayout>
