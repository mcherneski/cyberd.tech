---
import Card from "@components/Card.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSiteContent } from "@lib/content";
import { personJsonLd } from "@lib/jsonld";

const { projects } = await getSiteContent();
---

<BaseLayout title="Projects | Cyberd" description="Selected systems, case studies, and experiments." jsonLd={personJsonLd()} agentHref="/projects.md">
  <section class="container py-14">
    <p class="eyebrow accent-yellow">Archive</p>
    <h1 class="mt-3 text-6xl font-black tracking-[-0.09em]">Projects.</h1>
    <p class="mt-4 max-w-2xl text-xl leading-8 text-muted">
      Professional engagements across AI, cloud and serverless, and systems work.
    </p>
    <div class="grid-auto mt-8">
      {
        projects.map((project, index) => (
          <Card
            href={`/projects/${project.id}`}
            eyebrow={`${project.data.status} / ${project.data.category}`}
            title={project.data.title}
            summary={project.data.summary}
            accent={index % 3 === 0 ? "sky" : index % 3 === 1 ? "yellow" : "crimson"}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
