---
import { render, getCollection } from "astro:content";
import TagList from "@components/TagList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatLabel } from "@lib/content";
import { creativeWorkJsonLd } from "@lib/jsonld";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={`${project.data.title} | Projects | Cyberd`}
  description={project.data.summary}
  jsonLd={creativeWorkJsonLd(project)}
  agentHref={`/projects/${project.id}.md`}
>
  <article class="container py-14">
    <a class="font-mono text-sm font-bold" href="/projects">&lt;- Projects</a>
    <header class="surface mt-5 p-6 md:p-8">
      <p class="eyebrow accent-yellow">{formatLabel(`${project.data.status} / ${project.data.category}`)}</p>
      <h1 class="mt-3 text-5xl font-black tracking-[-0.08em] md:text-7xl">{project.data.title}</h1>
      <p class="mt-5 max-w-3xl text-xl leading-8 text-muted">{project.data.summary}</p>
      <div class="mt-6">
        <TagList tags={project.data.tags} />
      </div>
    </header>
    <div class="mt-8 grid gap-8 md:grid-cols-[1fr_280px]">
      <div class="prose surface p-6" data-pagefind-body>
        <span data-pagefind-meta={`title:${project.data.title}`} hidden></span>
        <span data-pagefind-meta="type:Project" hidden></span>
        <Content />
      </div>
      <aside class="grid content-start gap-4">
        <div class="surface-muted p-4">
          <p class="eyebrow accent-sky">Highlights</p>
          <ul class="mt-3 grid gap-2 text-sm font-bold">
            {project.data.highlights.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        {
          project.data.links.length > 0 && (
            <div class="surface p-4">
              <p class="eyebrow accent-crimson">Links</p>
              <div class="mt-3 grid gap-2">
                {project.data.links.map((link) => (
                  <a class="font-mono text-sm font-bold" href={link.href}>
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </aside>
    </div>
  </article>
</BaseLayout>
