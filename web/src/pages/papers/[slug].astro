---
import { getCollection, render } from "astro:content";
import TagList from "@components/TagList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatLabel } from "@lib/content";
import { creativeWorkJsonLd } from "@lib/jsonld";

export async function getStaticPaths() {
  const papers = await getCollection("papers", ({ data }) => !data.draft);
  return papers.map((paper) => ({
    params: { slug: paper.id },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const { Content } = await render(paper);
---

<BaseLayout
  title={`${paper.data.title} | Papers | Cyberd`}
  description={paper.data.summary}
  jsonLd={creativeWorkJsonLd(paper)}
  agentHref={`/papers/${paper.id}.md`}
>
  <article class="container py-14">
    <a class="font-mono text-sm font-bold" href="/papers">&lt;- Papers</a>
    <header class="surface mt-5 p-6 md:p-8">
      <p class="eyebrow accent-yellow">{formatLabel(paper.data.category)}</p>
      <h1 class="mt-3 text-5xl font-black tracking-[-0.08em] md:text-7xl">{paper.data.title}</h1>
      <p class="mt-5 max-w-3xl text-xl leading-8 text-muted">{paper.data.summary}</p>
      <div class="mt-6">
        <TagList tags={paper.data.tags} />
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        {paper.data.pdf && <a class="button" href={paper.data.pdf}>Download PDF</a>}
        {paper.data.citation && <p class="font-mono text-xs font-bold text-muted">{paper.data.citation}</p>}
      </div>
    </header>
    <div class="prose surface mt-8 p-6 md:p-8" data-pagefind-body>
      <span data-pagefind-meta={`title:${paper.data.title}`} hidden></span>
      <span data-pagefind-meta="type:Paper" hidden></span>
      <Content />
    </div>
  </article>
</BaseLayout>
