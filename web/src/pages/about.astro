---
import ContactForm from "@components/ContactForm.astro";
import ExperienceTimeline from "@components/ExperienceTimeline.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSiteContent } from "@lib/content";
import { personJsonLd } from "@lib/jsonld";
import { siteConfig } from "@lib/site";

const { credentials, testimonials } = await getSiteContent();
---

<BaseLayout title="File | Mike Cherneski" description="Enterprise architect and builder. Founder of Cyberd, co-founder and CTO of Moxa. A compressed view of experience across enterprise architecture, cloud, blockchain, and quantum." jsonLd={personJsonLd()} agentHref="/about.md">
  <section class="container grid gap-6 py-14">
    <div class="surface grid gap-6 p-6 md:grid-cols-[0.7fr_1.3fr] md:items-center md:gap-8 md:p-8">
      <img
        class="portrait w-40 max-w-[40vw] md:w-full md:max-w-none"
        src={siteConfig.photo}
        alt="Mike Cherneski"
        width="720"
        height="900"
        decoding="async"
      />
      <div>
        <p class="eyebrow accent-crimson">File</p>
        <h1 class="mt-3 text-5xl font-black tracking-[-0.09em] md:text-7xl">Mike Cherneski.</h1>
        <p class="text-muted mt-5 max-w-2xl text-xl leading-8">
          Enterprise architect and builder, designing sustainable systems. 
        </p>
        <p class="text-muted mt-4 max-w-2xl leading-8">
          I help organizations modernize on foundations they can trust: data that means something, governance that survives an audit, and infrastructure that runs without a hero. I've lived up and down the stack and now share that knowledge with you.
        </p>
      </div>
    </div>

    <aside class="surface-muted w-full p-5">
      <p class="eyebrow accent-sky">Signal</p>
      <ul class="mt-4 grid gap-3 font-bold">
        <li>Founder & principal, Cyberd</li>
        <li>Co-founder & CTO, Moxa</li>
        <li>Enterprise architecture, cloud, and AI modernization</li>
        <li>Full-stack blockchain (EVM); quantum-adjacent systems experience</li>
        <li>Based in Asheville, NC</li>
      </ul>
    </aside>
  </section>

  <ExperienceTimeline credentials={credentials} />

  {
    testimonials.length > 0 && (
      <section class="container py-12">
        <div class="grid-auto">
          {testimonials.map((item) => (
            <blockquote class="surface p-5">
              <p class="text-xl font-bold leading-8">"{item.data.quote}"</p>
              <footer class="mt-4 font-mono text-xs font-bold uppercase tracking-widest">
                {item.data.name} / {item.data.relationship}
              </footer>
            </blockquote>
          ))}
        </div>
      </section>
    )
  }

  <ContactForm />
</BaseLayout>
