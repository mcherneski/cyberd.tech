---
import ContactForm from "@components/ContactForm.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const offers = [
  {
    tier: "01",
    accent: "accent-sky",
    title: "AI Architecture Review",
    price: "from $8,500",
    duration: "3\u20135 days",
    pitch:
      "A second opinion on the system you're building or being sold. I review the architecture against a published framework and tell you, in writing, what holds, what fails, and what it will cost you.",
    includes: [
      "Review of proposed or existing AI/automation architecture",
      "Trust boundaries, audit trail, data governance, and cost model examined",
      "Findings memo: what holds, what fails, what to fix first",
      "Live walkthrough with your technical and business leads",
    ],
    best: "Best when a vendor proposal or internal build needs a disinterested expert before more money moves.",
  },
  {
    tier: "02",
    accent: "accent-yellow",
    title: "Executive AI Strategy Sprint",
    price: "from $15,000",
    duration: "1 week",
    pitch:
      "One compressed week with your leadership team that ends with a written strategy, investment priorities, and your first pilot scoped and ready to fund. The first step is a meeting. This is that meeting, industrialized.",
    includes: [
      "Discovery interviews with leadership and operational leads",
      "AI strategy memo aligned to measurable business outcomes",
      "Investment priorities ranked by expected return",
      "First pilot workflow scoped, with success criteria attached",
      "Half-day workshop to pressure-test the plan live",
    ],
    best: "Best when the board is asking for an AI plan and the honest answer is that there isn't one yet.",
  },
  {
    tier: "03",
    accent: "accent-crimson",
    title: "AI Readiness Assessment",
    price: "from $18,000",
    duration: "2 weeks",
    flagship: true,
    pitch:
      "The full diagnostic. Two weeks inside your data, systems, and current initiatives, scored against the framework's Pre-Implementation Checklist, delivered as a report your board can read.",
    includes: [
      "Interviews across finance, operations, and technology",
      "Data landscape and systems inventory review",
      "Audit of current and planned AI initiatives",
      "Scored assessment against the eleven-item readiness checklist",
      "Risk register with the failure modes that apply to you",
      "Prioritized twelve-month roadmap, sequenced and costed",
      "Executive briefing session on delivery",
    ],
    best: "Best before a major AI investment, or after one that isn't delivering and nobody can say why.",
  },
];

const process = [
  {
    step: "1",
    title: "Signal",
    body: "A short intro call. You describe the situation; I tell you honestly which engagement fits, or whether none does.",
  },
  {
    step: "2",
    title: "Scope",
    body: "A one-page statement of work: what's included, what's explicitly not, the deliverable, and the end date. Fixed scope, fixed price.",
  },
  {
    step: "3",
    title: "The work",
    body: "Interviews, review, and analysis on a set schedule. You'll always know where the engagement stands and what I need next.",
  },
  {
    step: "4",
    title: "Delivery",
    body: "A written deliverable and a live briefing, followed by two weeks of follow-up questions included. No engagement ends with a handoff into silence.",
  },
];
---

<BaseLayout
  title="Services | Cyberd"
  description="Fixed-scope engagements for AI adoption: architecture reviews, executive strategy sprints, and readiness assessments. Written verdicts, fixed prices, hard end dates."
  agentHref="/services.md"
>
  <section class="container py-14 md:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow accent-sky">Services</p>
      <h1 class="mt-4 text-5xl font-black leading-[0.95] tracking-[-0.09em] md:text-7xl">
        A verdict, in writing, on a deadline.
      </h1>
      <p class="text-muted mt-6 text-xl leading-8">
        Every engagement is fixed-scope and fixed-price, ends with a written deliverable you can hand to a board, and applies the framework published in
        <a href="/papers/intelligent-business">Intelligent Business</a>. No open-ended hourly work, and no report that tells you what you already knew.
      </p>
    </div>
  </section>

  <section class="container pb-12">
    <div class="grid gap-5">
      {
        offers.map((offer) => (
          <article
            class={`surface relative grid gap-6 p-6 md:grid-cols-[minmax(14rem,0.38fr)_1fr] md:gap-10 md:p-8 ${offer.flagship ? "outline outline-2 outline-offset-4 outline-[var(--color-crimson)]" : ""}`}
          >
            {offer.flagship && (
              <p class="eyebrow accent-crimson absolute -top-3 right-5 bg-[var(--color-paper)] px-2">Flagship</p>
            )}
            <div>
              <p class={`eyebrow ${offer.accent}`}>{offer.tier} / {offer.duration}</p>
              <h2 class="mt-3 text-3xl font-black tracking-[-0.06em] md:text-4xl">{offer.title}</h2>
              <p class="mt-3 font-mono text-lg font-bold">{offer.price}</p>
            </div>
            <div>
              <p class="text-muted leading-7">{offer.pitch}</p>
              <ul class="mt-5 grid gap-2 border-t pt-5 text-sm font-bold leading-6 sm:grid-cols-2 sm:gap-x-6">
                {offer.includes.map((item) => (
                  <li class="flex gap-2">
                    <span aria-hidden="true">&rarr;</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <p class="text-muted mt-5 text-sm leading-6">{offer.best}</p>
            </div>
          </article>
        ))
      }
    </div>
    <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-muted max-w-3xl text-sm leading-6">
        Prices are starting points for a single-entity, single-site organization; multi-entity structures and regulated
        industries scope up, never down mid-engagement. Every price is confirmed in the statement of work before anything begins.
      </p>
      <a class="button shrink-0 text-center" href="#contact">Start with a call</a>
    </div>
  </section>

  <section class="container py-12">
    <div class="surface-muted grid gap-6 p-6 md:grid-cols-[0.8fr_1.2fr] md:p-8">
      <div>
        <p class="eyebrow accent-yellow">After the diagnosis</p>
        <h2 class="mt-3 text-4xl font-black tracking-[-0.07em]">Build and workforce engagements.</h2>
        <p class="text-muted mt-4 leading-7">
          Two larger engagements are available, and both are scoped from an assessment rather than sold cold, because
          building before diagnosing is how AI projects fail.
        </p>
      </div>
      <div class="grid gap-4">
        <div class="surface p-5">
          <h3 class="text-xl font-black tracking-[-0.04em]">Pilot Workflow Build</h3>
          <p class="text-muted mt-2 leading-7">
            One process automated end to end on the architecture the assessment recommends: event queue, workers,
            knowledge layer, human checkpoint, and audit trail, with the before-and-after economics measured. Typically
            four to six weeks. Scoped after an assessment.
          </p>
        </div>
        <div class="surface p-5">
          <h3 class="text-xl font-black tracking-[-0.04em]">Workforce Transition Assessment</h3>
          <p class="text-muted mt-2 leading-7">
            For organizations planning, or regretting, AI-driven workforce changes: task inventories for affected roles,
            analysis of the work automation cannot absorb, a skills adjacency map, and a redeployment plan with measurable
            returns. Grounded in the research behind <a href="/notebook/the-1-27-problem">The $1.27 Problem</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="container py-12">
    <p class="eyebrow accent-crimson">How it runs</p>
    <h2 class="mt-3 text-4xl font-black tracking-[-0.07em]">The same process, every time.</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-4">
      {
        process.map((item) => (
          <div class="surface p-5">
            <p class="font-mono text-3xl font-black">{item.step}</p>
            <h3 class="mt-2 text-xl font-black tracking-[-0.04em]">{item.title}</h3>
            <p class="text-muted mt-2 text-sm leading-6">{item.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <ContactForm />
</BaseLayout>
