---
import SocialLinks from "@components/SocialLinks.astro";

const contactApiUrl = import.meta.env.PUBLIC_CONTACT_API_URL ?? "";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
const turnstileRequired = Boolean(contactApiUrl && turnstileSiteKey);
const turnstileConfigured = Boolean(turnstileSiteKey);
---

<section id="contact" class="container py-12">
  <div class="surface grid gap-8 p-6 md:grid-cols-[0.8fr_1.2fr] md:p-8">
    <div>
      <p class="eyebrow accent-crimson">Work with me</p>
      <h2 class="mt-3 text-4xl font-black tracking-[-0.07em]">Let's build something.</h2>
      <p class="text-muted mt-4">
        Data-readiness assessments, enterprise architecture and AI-modernization planning, and cloud consulting, as a project, retainer, or advisory call. Tell me what you're working on and I'll reply personally.
      </p>
      <SocialLinks />
    </div>
    <form
      class="grid gap-4"
      method="post"
      action={contactApiUrl || "/contact-disabled"}
      data-contact-form
      data-api={contactApiUrl}
      data-turnstile-required={turnstileRequired ? "true" : "false"}
    >
      <label class="grid gap-2 font-bold">
        Name
        <input class="field w-full" name="name" autocomplete="name" required maxlength="120" />
      </label>
      <label class="grid gap-2 font-bold">
        Email
        <input class="field w-full" type="email" name="email" autocomplete="email" required maxlength="180" />
      </label>
      <label class="hidden" aria-hidden="true">
        Company website
        <input name="website" tabindex="-1" autocomplete="off" />
      </label>
      <label class="grid gap-2 font-bold">
        Message
        <textarea class="field min-h-36 w-full" name="message" required maxlength="2000"></textarea>
      </label>
      {
        turnstileConfigured && (
          <div class="turnstile-slot" data-turnstile-slot>
            <div
              class="cf-turnstile"
              data-turnstile-gate
              data-sitekey={turnstileSiteKey}
              data-appearance="interaction-only"
              data-execution="execute"
              data-action="turnstile-spin-v1"
            />
          </div>
        )
      }
      <button class="button justify-self-start" type="submit">Send signal</button>
      <p class="text-muted font-mono text-xs" data-contact-status hidden />
      {
        !contactApiUrl && (
          <p class="text-muted font-mono text-xs">
            Set PUBLIC_CONTACT_API_URL after deploying the API to enable submissions.
          </p>
        )
      }
      {
        contactApiUrl && !turnstileRequired && (
          <p class="text-muted font-mono text-xs">
            Set PUBLIC_TURNSTILE_SITE_KEY to enable bot protection.
          </p>
        )
      }
    </form>
  </div>
</section>

{turnstileConfigured && (
  <>
    <script is:inline>
      window.onloadCyberdTurnstile = function () {
        var el = document.querySelector("[data-turnstile-gate]");
        if (!el || !window.turnstile) return;
        window.__cyberdTurnstileId = window.turnstile.render(el, {
          sitekey: el.getAttribute("data-sitekey"),
          appearance: "interaction-only",
          execution: "execute",
          action: "turnstile-spin-v1",
          callback: function (token) {
            window.dispatchEvent(new CustomEvent("cyberd-turnstile-token", { detail: { token: token } }));
          },
          "error-callback": function () {
            window.dispatchEvent(new CustomEvent("cyberd-turnstile-error"));
          },
        });
      };
    </script>
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=onloadCyberdTurnstile"
      async
      defer
      is:inline
    />
  </>
)}

<script>
  import { bindTurnstileGate, requestToken } from "../lib/turnstile-gate";

  bindTurnstileGate();

  function setContactStatus(form: HTMLFormElement, message: string, visible = true) {
    const status = form.querySelector<HTMLElement>("[data-contact-status]");
    if (!status) return;
    status.textContent = message;
    status.hidden = !visible;
  }

  function wireContactForm(form: HTMLFormElement) {
    if (form.dataset.wired === "true") return;
    form.dataset.wired = "true";

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const api = form.getAttribute("data-api");
      if (!api) {
        setContactStatus(form, "Contact API URL is not configured.");
        return;
      }

      const turnstileRequired = form.getAttribute("data-turnstile-required") === "true";
      const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');

      if (submitButton) submitButton.disabled = true;

      // Turnstile tokens are single-use. Request a fresh token from the shared
      // widget and let the contact API verify it server-side exactly once.
      let token = "";
      if (turnstileRequired) {
        setContactStatus(form, "Verifying…");
        try {
          token = await requestToken();
        } catch {
          setContactStatus(form, "Verification unavailable. Reload the page and try again.");
          if (submitButton) submitButton.disabled = false;
          return;
        }
      }

      setContactStatus(form, "Sending…");

      try {
        const payload = {
          name: (form.elements.namedItem("name") as HTMLInputElement).value,
          email: (form.elements.namedItem("email") as HTMLInputElement).value,
          message: (form.elements.namedItem("message") as HTMLTextAreaElement).value,
          website: (form.elements.namedItem("website") as HTMLInputElement).value,
          token,
        };

        const response = await fetch(api, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const result = (await response.json()) as { ok?: boolean; error?: string };
        if (!response.ok || !result.ok) {
          setContactStatus(form, result.error ?? "Could not send message.");
          return;
        }

        form.reset();
        setContactStatus(form, "Message sent.", false);
      } catch {
        setContactStatus(form, "Network error. Try again.");
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  }

  document.querySelectorAll<HTMLFormElement>("[data-contact-form]").forEach(wireContactForm);
  document.addEventListener("astro:after-swap", () => {
    document.querySelectorAll<HTMLFormElement>("[data-contact-form]").forEach(wireContactForm);
  });
</script>
