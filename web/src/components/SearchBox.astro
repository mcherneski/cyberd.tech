<div class="site-search surface p-4 md:p-5" data-site-search>
  <form role="search" class="site-search__form" data-site-search-form>
    <label class="eyebrow accent-sky" for="site-search-input">Search</label>
    <div class="mt-3 flex flex-col gap-3 sm:flex-row">
      <input
        id="site-search-input"
        class="field min-h-11 w-full flex-1"
        type="search"
        name="q"
        autocomplete="off"
        enterkeyhint="search"
        placeholder="Notebook, projects, papers…"
        data-site-search-input
        aria-controls="site-search-results"
        aria-expanded="false"
      />
      <button class="button shrink-0" type="submit">Search</button>
    </div>
  </form>
  <p class="text-muted mt-3 text-sm" data-site-search-status></p>
  <p class="text-muted mt-3 text-sm is-hidden" data-site-search-empty>No matches yet. Try different terms.</p>
  <ol id="site-search-results" class="site-search__results mt-4 grid gap-3" data-site-search-results hidden></ol>
</div>

<script>
  import { initSiteSearch } from "../lib/site-search";
  initSiteSearch();
</script>
