# Copy to .env for local dev and machine deploy:
#   copy .env.example .env
#
# Web build (npm run build -w web) reads PUBLIC_* and SITE_URL.
# CDK deploy (cd infra && npx cdk deploy) reads the rest.

# --- Web build ---
SITE_URL=https://d2nwxiin456b6k.cloudfront.net
PUBLIC_CONTACT_API_URL=https://4uiek417ne.execute-api.us-east-1.amazonaws.com/contact
PUBLIC_SOCIAL_API_URL=https://4uiek417ne.execute-api.us-east-1.amazonaws.com/social-links
PUBLIC_TURNSTILE_SITE_KEY=
PUBLIC_TURNSTILE_WORKER_URL=

# --- CDK / AWS (account: cyberdtech / 752297506265) ---
CDK_DEFAULT_ACCOUNT=752297506265
CDK_DEFAULT_REGION=us-east-1

# Custom domain (optional — leave blank while using CloudFront URL)
DOMAIN_NAME=
HOSTED_ZONE_ID=
HOSTED_ZONE_NAME=

# --- Contact form (SES — verify these identities in AWS first) ---
CONTACT_TO_ADDRESS=
CONTACT_FROM_ADDRESS=

# --- Social links (Lambda only — not embedded in static HTML) ---
SOCIAL_LINKEDIN_URL=
SOCIAL_X_URL=
SOCIAL_TELEGRAM_URL=

# --- Cloudflare Turnstile Spin (Worker holds the secret — do not commit secrets) ---
# Create widget + deploy siteverify Worker via Turnstile Spin, then set:
#   PUBLIC_TURNSTILE_SITE_KEY=<sitekey from widget-create>
#   PUBLIC_TURNSTILE_WORKER_URL=<worker URL from worker-deploy>
#   TURNSTILE_SITEVERIFY_URL=<same worker URL for Lambda backend verify>
TURNSTILE_SITEVERIFY_URL=
# SSM SecureString parameter holding the Turnstile secret key (fallback verify path).
# Create once: aws ssm put-parameter --name /cyberd/portfolio/turnstile-secret-key --type SecureString --value <secret>
TURNSTILE_SECRET_PARAMETER=/cyberd/portfolio/turnstile-secret-key

# Cloudflare API token (local Spin setup only — never commit):
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Local testing only (always-pass Turnstile keys; siteverify still needs a deployed Worker):
# PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
