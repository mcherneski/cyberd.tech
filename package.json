{
  "name": "cyberd-portfolio",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "workspaces": [
    "web",
    "infra"
  ],
  "scripts": {
